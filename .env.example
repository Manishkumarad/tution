PORT=4000
NODE_ENV=development
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?uselibpqcompat=true&sslmode=require
DB_SSL_REJECT_UNAUTHORIZED=false
DB_POOL_MAX=30
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_MAX_USES=7500
DB_KEEPALIVE=true
DB_RETRY_ATTEMPTS=2
DB_RETRY_DELAY_MS=120
DB_LOG_SLOW_QUERIES=true
DB_SLOW_QUERY_MS=250
METRICS_ENABLED=true
METRICS_TOKEN=
REDIS_ENABLED=false
REDIS_URL=
SQS_ENABLED=false
AWS_REGION=ap-south-1
SQS_REMINDER_QUEUE_URL=
SQS_LONG_POLL_SECONDS=20
PARTITION_DUAL_WRITE=false
PARTITION_READ_TABLES=false
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
CORS_ORIGIN=http://localhost:3000
REMINDER_CRON_EXPRESSION=0 9 * * *
NOTIFICATION_WORKER_CRON_EXPRESSION=*/5 * * * *
REMINDER_TIMEZONE=Asia/Kolkata
REMINDER_CHANNELS=sms,email
NOTIFICATION_MAX_RETRIES=5
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@tution.app
OWNER_ALERT_EMAIL=
SMS_PROVIDER_URL=
SMS_PROVIDER_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
WHATSAPP_PROVIDER_URL=
